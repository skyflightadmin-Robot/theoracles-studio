---
import NewsletterForm from './NewsletterForm.astro';

const socials = [
  { label: 'X', href: 'https://x.com/oracles_studio' },
  { label: 'Instagram', href: 'https://www.instagram.com/theoracles.studio/' },
  { label: 'YouTube', href: 'https://www.youtube.com/@theoracles.studio' },
];
---

<footer class="w-full px-[var(--space-gutter)] py-12 mt-24 border-t border-[var(--color-hairline)] font-mono text-[var(--text-small)] text-[var(--color-muted)]">
  <!-- Newsletter row — sits above the tri-column wordmark/socials/year
       row. Netlify captures submissions; first-pass follow-up is manual. -->
  <div class="pb-10 mb-10 border-b border-[var(--color-hairline)]">
    <NewsletterForm variant="footer" />
  </div>

  <div class="flex flex-col gap-8 md:flex-row md:items-start md:justify-between">
    <div>
      <p class="uppercase tracking-wide text-[var(--color-ink)]">The Oracles</p>
      <p class="mt-1">Where law and story meet.</p>
      <p class="mt-4">
        <a href="mailto:hello@theoracles.studio" class="hover:text-[var(--color-ink)]">
          hello@theoracles.studio
        </a>
      </p>
    </div>

    <nav class="slash-nav flex flex-wrap" aria-label="Social">
      {socials.map((s) => (
        <a
          href={s.href}
          target="_blank"
          rel="noopener"
          class="hover:text-[var(--color-vermillion)] transition-colors"
        >
          {s.label}
        </a>
      ))}
    </nav>

    <div class="md:text-right">
      <span class="bracket-count">MMXXVI</span>
      <p class="mt-1">&copy; The Oracles Studio</p>
    </div>
  </div>
</footer>
