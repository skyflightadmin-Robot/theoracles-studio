---
import BaseLayout from '../layouts/BaseLayout.astro';
import HeroReel from '../components/HeroReel.astro';
---

<BaseLayout
  title="The Oracles — where law and story meet"
  description="A small nonprofit studio telling stories that promote the goodness of God’s law. Christian education. Pastoral care. Behind-the-scenes work for organizations whose stories matter more than their marketing budget."
>
  <!-- Hero: full-bleed type paired with a letterboxed BTS reel on the right.
       Grid collapses to a single column on narrow viewports so the reel
       stacks under the type instead of squeezing. -->
  <section class="hero-grid px-[var(--space-gutter)] pt-[clamp(2rem,6vw,5rem)] pb-[clamp(4rem,10vw,9rem)]">
    <div class="hero-grid__type">
      <p class="font-mono text-[var(--text-small)] text-[var(--color-muted)] mb-6">
        <span class="bracket-count">01</span>
        <span class="ml-4">Who we are</span>
      </p>

      <h1 class="font-[family-name:var(--font-display)] uppercase leading-[0.9] tracking-tight hero-title">
        Where&nbsp;law<br />
        and&nbsp;story<br />
        <span class="text-[var(--color-vermillion)]">meet.</span>
      </h1>

      <p class="mt-10 max-w-xl text-[var(--text-body)] leading-relaxed">
        We&rsquo;re a small nonprofit studio telling stories that promote
        the goodness of God&rsquo;s law.
      </p>
    </div>

    <aside class="hero-grid__reel">
      <HeroReel />
    </aside>
  </section>

  <style>
    .hero-grid {
      display: grid;
      grid-template-columns: 1fr;
      gap: clamp(2rem, 5vw, 4rem);
      align-items: center;
    }
    /* Scale the hero headline down on the 2-column layout so the reel
     * sits next to the type rather than far below it. */
    .hero-title {
      font-size: clamp(3rem, 10vw, 8rem);
    }
    @media (min-width: 900px) {
      .hero-grid {
        grid-template-columns: minmax(0, 1.05fr) minmax(0, 1fr);
      }
      .hero-title {
        font-size: clamp(3rem, 7.5vw, 6rem);
      }
      .hero-grid__reel {
        align-self: center;
      }
    }
  </style>

  <!-- Work preview — vermillion full-bleed block, a nod to THE LINE.
       Links out to the portfolio page. -->
  <section
    class="w-full bg-[var(--color-vermillion)] text-[var(--color-paper)]"
    style="clip-path: polygon(0 8%, 100% 0, 100% 92%, 0 100%); padding: clamp(6rem,16vw,14rem) var(--space-gutter);"
  >
    <p class="font-mono text-[var(--text-small)] opacity-80 mb-6">
      <span class="bracket-count">02</span>
      <span class="ml-4">Work</span>
    </p>
    <h2 class="font-[family-name:var(--font-display)] uppercase leading-[0.9]"
        style="font-size: var(--text-display);">
      Many&nbsp;stories.<br />
      One&nbsp;law.
    </h2>
    <p class="mt-8 max-w-xl">
      Christian education. Pastoral care. And more — all aimed at
      imprinting the good, beautiful, and true nature of the law of God.
    </p>
    <a href="/work"
       class="inline-block mt-10 font-mono text-[var(--text-small)] uppercase tracking-wider border-b border-[var(--color-paper)] pb-0.5 hover:opacity-80 transition-opacity">
      / See the work
    </a>
  </section>

  <!-- About teaser -->
  <section class="px-[var(--space-gutter)] py-[clamp(4rem,10vw,10rem)]">
    <p class="font-mono text-[var(--text-small)] text-[var(--color-muted)] mb-6">
      <span class="bracket-count">03</span>
      <span class="ml-4">About</span>
    </p>
    <h2 class="font-[family-name:var(--font-display)] uppercase leading-[0.9] max-w-4xl"
        style="font-size: var(--text-h1);">
      A small studio, a specific mission.
    </h2>
    <a href="/about"
       class="inline-block mt-10 font-mono text-[var(--text-small)] uppercase tracking-wider border-b border-[var(--color-ink)] pb-0.5 hover:text-[var(--color-vermillion)] hover:border-[var(--color-vermillion)] transition-colors">
      / Read more
    </a>
  </section>

  <!-- Support section.
       Anchor `support` matches the nav label ("Support"). A secondary
       `donate` anchor is kept so any external link that still points at
       /#donate (old nav, email signatures, bookmarks) scrolls here too.
       CTA opens GivingFuel in a new tab. -->
  <section
    id="support"
    class="px-[var(--space-gutter)] py-[clamp(5rem,12vw,12rem)] border-t border-[var(--color-hairline)]"
  >
    <span id="donate" aria-hidden="true"></span>
    <p class="font-mono text-[var(--text-small)] text-[var(--color-muted)] mb-6">
      <span class="bracket-count">04</span>
      <span class="ml-4">Support</span>
    </p>
    <h2 class="font-[family-name:var(--font-display)] uppercase leading-[0.9] max-w-4xl"
        style="font-size: var(--text-h1);">
      Stories that otherwise<br />
      wouldn&rsquo;t&nbsp;be&nbsp;told.
    </h2>
    <div class="mt-10 max-w-xl text-[var(--text-body)] leading-relaxed space-y-6">
      <p>
        Most of our projects are three- to five-minute films &mdash; the kind
        a production studio would typically charge $3,000 to $5,000 to make.
        Camera bodies and lenses. Lighting. Audio. Travel to where the story
        is. And the editing hours that turn footage into something worth
        watching.
      </p>
      <p>
        The Oracles helps smaller ministries and organizations tell those
        stories at little to no cost to them. Not because the work costs
        less to produce &mdash; because donors cover the gap.
      </p>
      <p>
        Your gift funds the gear, the crew, and the time in between.
      </p>
    </div>

    <!-- Pull-quote from Reign's headmaster — social proof for the ask. -->
    <figure class="mt-14 pl-6 border-l-2 border-[var(--color-vermillion)] max-w-3xl">
      <blockquote class="font-[family-name:var(--font-display)] uppercase leading-[1.05]"
                  style="font-size: var(--text-h2);">
        &ldquo;The team did a great job of creating a story on film
        that captures the heartbeat of our ministry.&rdquo;
      </blockquote>
      <figcaption class="mt-5 font-mono text-[var(--text-small)] uppercase tracking-wider text-[var(--color-muted)]">
        &mdash; Matt Vlahovich, Headmaster · Reign Christian Academy
      </figcaption>
    </figure>

    <a
      href="https://urbanskye.givingfuel.com/aaron-sanford"
      target="_blank"
      rel="noopener"
      class="inline-flex items-center gap-3 mt-12 bg-[var(--color-vermillion-strong)] text-[var(--color-paper)] font-mono text-[var(--text-small)] uppercase tracking-wider px-8 py-4 hover:opacity-90 transition-opacity"
    >
      <span>/ Donate</span>
      <span aria-hidden="true">&rarr;</span>
    </a>
    <p class="mt-6 max-w-xl font-mono text-[var(--text-small)] text-[var(--color-muted)] leading-relaxed">
      Gifts are processed by Urban Skye, a U.S. 501(c)(3) nonprofit, and are
      tax-deductible to the full extent allowed by law. Secure giving via
      urbanskye.givingfuel.com.
    </p>
  </section>
</BaseLayout>
