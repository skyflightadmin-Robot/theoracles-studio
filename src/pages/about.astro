---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="About — The Oracles">
  <!-- Page header -->
  <section class="px-[var(--space-gutter)] pt-[clamp(4rem,10vw,9rem)] pb-[clamp(2rem,6vw,5rem)]">
    <p class="font-mono text-[var(--text-small)] text-[var(--color-muted)] mb-6">
      <span class="bracket-count">About</span>
    </p>
    <h1 class="font-[family-name:var(--font-display)] uppercase leading-[0.9] max-w-5xl"
        style="font-size: var(--text-display);">
      A small studio,<br />
      a specific mission.
    </h1>
  </section>

  <!-- Three-part about body, editorial two-column feel -->
  <section class="px-[var(--space-gutter)] pb-24">
    <div class="max-w-3xl space-y-20">
      <!-- What -->
      <div>
        <p class="font-mono text-[var(--text-small)] text-[var(--color-vermillion)] mb-4 uppercase tracking-wider">
          What is The Oracles?
        </p>
        <div class="space-y-6 text-[var(--text-body)] leading-relaxed">
          <p>
            We&rsquo;re a small nonprofit studio telling stories that promote
            the goodness of God&rsquo;s law.
          </p>
          <p>
            The name has its roots in the Hebrew word
            <span class="font-[family-name:var(--font-display)] text-[var(--color-ink)]" dir="rtl">מַשָּׂא</span>
            <span class="text-[var(--color-muted)]">(pronounced <em>mas-saw</em>)</span>.
            <span class="font-[family-name:var(--font-display)]" dir="rtl">מַשָּׂא</span>
            is used about a dozen times in Isaiah to introduce a word from God.
          </p>
        </div>
      </div>

      <!-- Why -->
      <div>
        <p class="font-mono text-[var(--text-small)] text-[var(--color-vermillion)] mb-4 uppercase tracking-wider">
          Why law and story?
        </p>
        <div class="space-y-6 text-[var(--text-body)] leading-relaxed">
          <p>
            We believe a large part of the Christian church has lost its
            love for the arts and for God&rsquo;s law.
          </p>
          <p>
            As a studio we use the visual arts to tell stories that are
            designed to imprint the good, beautiful, and true nature of
            the law of God.
          </p>
        </div>
      </div>

      <!-- Who -->
      <div>
        <p class="font-mono text-[var(--text-small)] text-[var(--color-vermillion)] mb-4 uppercase tracking-wider">
          Who are we?
        </p>
        <div class="space-y-8">
          <div class="flex gap-6 items-baseline">
            <p class="font-[family-name:var(--font-display)] uppercase text-[var(--text-h3)] shrink-0">
              Dabe
            </p>
            <p class="text-[var(--text-body)] leading-relaxed">
              A seasoned illustrator who acts as the director, creative
              influence, and primary storyteller.
            </p>
          </div>
          <div class="flex gap-6 items-baseline">
            <p class="font-[family-name:var(--font-display)] uppercase text-[var(--text-h3)] shrink-0">
              Aaron
            </p>
            <p class="text-[var(--text-body)] leading-relaxed">
              A former pastor who functions as the DP/Editor to bring
              the vision to life.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Psalm 1 — full-bleed typographic display.
       This is the most texturally interesting copy on the site;
       it earns the oversized treatment. -->
  <section class="w-full bg-[var(--color-ink)] text-[var(--color-paper)] px-[var(--space-gutter)] py-[clamp(5rem,12vw,10rem)]">
    <p class="font-mono text-[var(--text-small)] text-[var(--color-vermillion)] mb-10 uppercase tracking-wider">
      Psalm 1 &middot; God&rsquo;s art intro
    </p>
    <blockquote class="font-[family-name:var(--font-display)] uppercase leading-[1.05] max-w-5xl"
                style="font-size: var(--text-h1);">
      Blessed is the man<br />
      <span class="inline-block pl-[1em]">who walks not in the counsel of the wicked,</span><br />
      nor stands in the way of sinners,<br />
      <span class="inline-block pl-[1em]">nor sits in the seat of scoffers;</span><br />
      but his delight is in the law of the Lord,<br />
      <span class="inline-block pl-[1em]">and on his law he meditates day and night.</span>
    </blockquote>
  </section>
</BaseLayout>
